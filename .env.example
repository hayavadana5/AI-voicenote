# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# Public base URL (used to build audio file URLs returned in responses)
# Change to your Render / Railway domain in production
BASE_URL=http://localhost:5000

# ─── MongoDB ──────────────────────────────────────────────────────────────────
# Local:   mongodb://localhost:27017/voice_assistant
# Atlas:   mongodb+srv://<user>:<password>@cluster.mongodb.net/voice_assistant
MONGODB_URI=mongodb://localhost:27017/voice_assistant

# ─── OpenAI (Whisper STT + GPT summarization + TTS) ──────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here

# Optional: override defaults
OPENAI_SUMMARIZE_MODEL=gpt-4o-mini
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=alloy          # alloy | echo | fable | onyx | nova | shimmer

# ─── AssemblyAI (STT fallback, used when OPENAI_API_KEY is not set) ───────────
ASSEMBLYAI_API_KEY=your-assemblyai-key-here

# ─── Google Cloud TTS (optional — used when TTS_PROVIDER=google) ─────────────
GOOGLE_TTS_API_KEY=your-google-api-key-here
GOOGLE_TTS_VOICE=en-US-Neural2-C
GOOGLE_TTS_LANGUAGE=en-US

# Set to "google" to force Google TTS; otherwise OpenAI is used when available
TTS_PROVIDER=openai

# ─── Upload limits ────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=50

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated origins, or * to allow all
CORS_ORIGIN=*
